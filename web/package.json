    "leaflet": "^1.9.4",
    "next": "15.2.2",
    "postcss": "^8",
    "postcss-loader": "^8.2.0",
    "puppeteer": "^24.31.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
